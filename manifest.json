{
  "manifest_version": 3,
  "name": "Biblionet to WikiCite",
  "version": "1.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "biblionet-wikicite@wikipedia-el"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://biblionet.gr/*",
        "*://www.biblionet.gr/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}