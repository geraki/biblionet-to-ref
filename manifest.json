{
  "manifest_version": 3,
  "name": "Biblionet to WikiCite",
  "version": "1.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "biblionet-wikicite@wikipedia-el"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}