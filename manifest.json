{
  "manifest_version": 3,
  "name": "Biblionet to WikiCite",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://biblionet.gr/*", "*://www.biblionet.gr/*"],
      "js": ["content.js"]
    }
  ]
}